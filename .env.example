# Shared
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# API
APP_NAME=PromptShield API
API_PREFIX=/api/v1
DEMO_MODE=true
DATABASE_URL=sqlite:///./promptshield.db
APP_SECRET=change-this-secret-in-production
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAPPING_ENCRYPTION_KEY=
ADMIN_PASSWORD=promptshield-admin
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
MAX_TEXT_LENGTH=8000
DEFAULT_MODE=ml_based
ML_ENABLE_TRANSFORMER=true
ML_CLASSIFIER_TASK=text-classification
ML_CLASSIFIER_MODEL=../models/security_classifier_v3
ML_CONFIDENCE_THRESHOLD=0.35
ML_INJECTION_BLOCK_THRESHOLD=0.62
ML_MAX_CLASSIFICATION_CHARS=2000
PERSON_NER_MODEL=Davlan/distilbert-base-multilingual-cased-ner-hrl
PERSON_NER_FALLBACK_MODEL=dslim/bert-base-NER
PERSON_NER_MIN_SCORE=0.65

# Chat response provider
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
LLM_TIMEOUT_SECONDS=20

# If you prefer zero-shot model-based routing, switch to:
# ML_CLASSIFIER_TASK=zero-shot-classification
# ML_CLASSIFIER_MODEL=joeddav/xlm-roberta-large-xnli
